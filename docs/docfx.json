{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "namespaceLayout": "nested"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "robots.txt"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "sitemap": {
      "baseUrl": "https://nvborisenko.github.io/Selenium.webdriver.bidi.cdp/",
      "changefreq": "weekly",
      "priority": 0.5
    },
    "globalMetadata": {
      "_appName": "CDP over WebDriver BiDi",
      "_appTitle": "CDP over WebDriver BiDi",
      "_appLogoPath": "images/cdp-logo.svg",
      "_appFaviconPath": "images/cdp-logo.png",
      "_enableSearch": true,
      "pdf": false,
      "_gitContribute": {
        "repo": "https://github.com/nvborisenko/Selenium.webdriver.bidi.cdp",
        "branch": "main"
      }
    }
  }
}